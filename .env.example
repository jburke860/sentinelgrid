MINIO_BUCKET=sentinelgrid-raw
API_BASE_URL=http://localhost:8000

MQTT_USERNAME=sentinelgrid
MQTT_PASSWORD=sentinelgrid
# SENTINELGRID_API_KEY=change-me
SENTINELGRID_RATE_LIMIT_PER_MIN=600
