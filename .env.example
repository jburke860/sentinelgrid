# IsolationForest retraining: minimum recent low-risk readings before the
# worker swaps from the synthetic-fit model to one learned from real data.
SENTINELGRID_IFOREST_MIN_SAMPLES=1000

# Webhook alerts for newly-opened incidents (unset = disabled).
